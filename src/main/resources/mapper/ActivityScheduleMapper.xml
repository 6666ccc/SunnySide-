<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.lc.sunnyside.mapper.ActivityScheduleMapper">

    <select id="selectByDate" resultType="cn.lc.sunnyside.POJO.DO.ActivitySchedule">
        SELECT *
        FROM activity_schedule
        WHERE activity_date = #{date}
    </select>

    <select id="selectById" resultType="cn.lc.sunnyside.POJO.DO.ActivitySchedule">
        SELECT *
        FROM activity_schedule
        WHERE id = #{id}
    </select>

</mapper>
