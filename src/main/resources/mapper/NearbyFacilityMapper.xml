<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.project.mapper.NearbyFacilityMapper">

    <select id="selectByDeptId" resultType="com.example.project.pojo.entity.NearbyFacility">
        SELECT id,
               dept_id,
               facility_name,
               facility_type,
               location,
               distance,
               created_at
        FROM nearby_facility
        WHERE dept_id = #{deptId}
        ORDER BY facility_type, id
    </select>
</mapper>
