<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.lc.sunnyside.mapper.FamilyElderRelationMapper">

    <select id="selectByFamilyId" resultType="cn.lc.sunnyside.POJO.DO.FamilyElderRelation">
        SELECT *
        FROM family_elder_relation
        WHERE family_id = #{familyId}
    </select>

    <select id="selectByElderId" resultType="cn.lc.sunnyside.POJO.DO.FamilyElderRelation">
        SELECT *
        FROM family_elder_relation
        WHERE elder_id = #{elderId}
    </select>

    <select id="existsRelation" resultType="java.lang.Integer">
        SELECT COUNT(1)
        FROM family_elder_relation
        WHERE family_id = #{familyId}
          AND elder_id = #{elderId}
    </select>

</mapper>
