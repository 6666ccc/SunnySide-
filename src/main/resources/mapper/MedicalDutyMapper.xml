<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.lc.sunnyside.mapper.MedicalDutyMapper">

    <select id="selectOnDuty" resultType="cn.lc.sunnyside.POJO.DO.MedicalDuty">
