<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.lc.sunnyside.mapper.RelativeUserMapper">

    <select id="selectById" resultType="cn.lc.sunnyside.POJO.DO.RelativeUser">
        SELECT *
        FROM relative_user
        WHERE id = #{id}
    </select>

    <select id="selectByPhone" resultType="cn.lc.sunnyside.POJO.DO.RelativeUser">
        SELECT *
        FROM relative_user
        WHERE phone = #{phone}
    </select>

    <select id="selectByUsername" resultType="cn.lc.sunnyside.POJO.DO.RelativeUser">
        SELECT *
        FROM relative_user
        WHERE username = #{username}
    </select>

</mapper>
